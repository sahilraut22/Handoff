{
  "name": "handoff-cli",
  "version": "3.1.2",
  "type": "module",
  "description": "Seamless context transfer, decision journaling, and workspace management for AI coding agents",
  "bin": {
    "handoff": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "context-transfer",
    "handoff",
    "claude",
    "codex",
    "tmux",
    "multi-agent",
    "decision-journal",
    "workspace"
  ],
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^14.0.0",
    "diff": "^8.0.0",
    "gpt-tokenizer": "^2.9.0",
    "ignore": "^7.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sahilraut22/Handoff.git"
  },
  "homepage": "https://github.com/sahilraut22/Handoff#readme",
  "bugs": {
    "url": "https://github.com/sahilraut22/Handoff/issues"
  }
}
